#!/usr/bin/env python3

import csv
import sys
from datetime import datetime, timezone
try:
    # Python 3.9+ 內建支援
    from zoneinfo import ZoneInfo
except ImportError:
    ZoneInfo = None

def convert_unix_csv_to_gpx(input_csv):
    try:
        # 1. 設定洛杉磯時區
        la_tz = ZoneInfo("America/Los_Angeles") if ZoneInfo else None

        with open(input_csv, mode='r', encoding='utf-8') as f:
            reader = csv.DictReader(f)
            data = list(reader)

        if not data:
            print("❌ 錯誤：CSV 檔案中沒有數據。")
            return

        processed_points = []
        for row in data:
            unix_ts = int(row['time'])
            # 將 Unix 時間戳轉為 UTC 時間，再轉為洛杉磯時間
            dt_utc = datetime.fromtimestamp(unix_ts, tz=timezone.utc)
            dt_la = dt_utc.astimezone(la_tz) if la_tz else dt_utc
            
            processed_points.append({
                'lat': row['lat'],
                'lon': row['lon'],
                'alt': row['alt'],
                'time': dt_la
            })

        # 2. 自動命名：YYYYMMDD_HHMMSS-HHMMSS.gpx (洛杉磯時間)
        start_pt = processed_points[0]['time']
        end_pt = processed_points[-1]['time']
        file_name = f"{start_pt.strftime('%Y%m%d_%H%M%S')}-{end_pt.strftime('%H%M%S')}.gpx"

        # 3. 建立標準 GPX 格式
        gpx = [
            '<?xml version="1.0" encoding="UTF-8"?>',
            '<gpx version="1.1" creator="Yuleshow_Unix_GPX_v6" xmlns="http://www.topografix.com/GPX/1/1">',
            '  <trk>',
            f'    <name>Track_{start_pt.strftime("%Y%m%d")}</name>',
            '    <trkseg>'
        ]

        for pt in processed_points:
            # 輸出 ISO 格式時間（會自動包含 -08:00 或 -07:00 偏移）
            iso_time = pt['time'].isoformat()
            gpx.append(f'      <trkpt lat="{pt["lat"]}" lon="{pt["lon"]}">')
            gpx.append(f'        <ele>{pt["alt"]}</ele>')
            gpx.append(f'        <time>{iso_time}</time>')
            gpx.append('      </trkpt>')

        gpx.extend(['    </trkseg>', '  </trk>', '</gpx>'])

        # 4. 寫入檔案
        with open(file_name, 'w', encoding='utf-8') as f:
            f.write('\n'.join(gpx))

        print(f"✅ 轉換成功！(基於衛星 Unix 時間戳)")
        print(f"⏰ 洛杉磯起始：{start_pt.strftime('%Y-%m-%d %H:%M:%S')}")
        print(f"⏰ 洛杉磯結束：{end_pt.strftime('%H:%M:%S')}")
        print(f"📂 生成檔案：{file_name}")

    except Exception as e:
        print(f"❌ 錯誤：{e}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("💡 使用方式：python3 yuleshow-csv2gpx.py 你的檔案.csv")
    else:
        convert_unix_csv_to_gpx(sys.argv[1])
