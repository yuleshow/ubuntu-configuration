#!/bin/bash

# ====== 使用者自訂 ======
MYSQL_USER="digikamuser"
MYSQL_PASS="dkpass123"  # 如果你不想在這裡寫密碼，可以改用 .my.cnf 檔
BACKUP_DIR="$HOME/Backups/digikam"
DB_NAME="digikam"
KEEP_DAYS=14
# ========================

TIMESTAMP=$(date '+%Y%m%d_%H%M%S')
FILENAME="${DB_NAME}_${TIMESTAMP}.sql.gz"

mkdir -p "$BACKUP_DIR"

# 執行備份
mysqldump -u "$MYSQL_USER" -p"$MYSQL_PASS" --databases "$DB_NAME" | gzip > "${BACKUP_DIR}/${FILENAME}"

# 檢查成功與否
if [ $? -eq 0 ]; then
    echo "✅ 備份成功：$FILENAME"
else
    echo "❌ 備份失敗！"
    exit 1
fi

# 清理舊備份
find "$BACKUP_DIR" -name "${DB_NAME}_*.sql.gz" -type f -mtime +$KEEP_DAYS -exec rm {} \;

echo "🧹 清理 $KEEP_DAYS 天前的舊備份完成"
     